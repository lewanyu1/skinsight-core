# ==========================================
# 1. 操作系统相关 (macOS)
# ==========================================
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# ==========================================
# 2. IDE 与编辑器 (PyCharm 主力)
# ==========================================
.idea/
*.iml
*.iws
out/
.vscode/

# ==========================================
# 3. 虚拟环境 (Conda & Poetry)
# ==========================================
# Conda
.conda/
env/
envs/

# Poetry / 标准 Virtualenv
.venv/
venv/
ENV/
env.bak/
venv.bak/

# 注意：千万不要忽略 poetry.lock 文件，它需要被提交以保证依赖版本一致！

# ==========================================
# 4. Python 运行时与编译产物
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/

# ==========================================
# 5. 项目核心与敏感信息 (安全至上)
# ==========================================
# 环境变量与机密配置
.env
.env.*
!.env.example  # 允许提交一个脱敏的环境变量模板

# 日志文件
logs/
*.log

# ==========================================
# 6. 量化与采集模块产生的本地数据
# ==========================================
# 避免将大量采集或计算产生的临时数据提交到 Git
data/
*.csv
*.parquet
*.json
# 排除不想忽略的 JSON，例如配置文件：!config.json

# ==========================================
# 7. 测试与代码覆盖率工具
# ==========================================
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/